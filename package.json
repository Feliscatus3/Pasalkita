{
  "name": "pragmatic-papers",
  "version": "2.2.0",
  "description": "The Pragmatic Papers",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/install-fonts.mjs",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "pnpm dev:db && pnpm dev:next && pnpm dev:db-down",
    "dev:db": "docker compose -p pragmatic-papers -f docker-compose.yml up -d",
    "dev:db-nuke": "pnpm dev:db && echo y | pnpm payload migrate:fresh && pnpm dev:db-down",
    "dev:db-down": "docker compose -p pragmatic-papers -f docker-compose.yml down",
    "dev:next": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 8000 --turbopack",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:ci": "cross-env NODE_OPTIONS=--no-deprecation eslint . --max-warnings 0",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint --fix .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation PAYLOAD_CONFIG_PATH=src/payload.config.ts payload",
    "reinstall": "node scripts/clean.mjs && pnpm install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "check-types": "cross-env NODE_OPTIONS=--no-deprecation tsc --noEmit",
    "ci": "payload migrate && pnpm build",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create",
    "postmigrate:create": "prettier --write src/migrations",
    "migrate:redo": "node scripts/redo-last-migration.mjs",
    "migrate:status": "payload migrate:status",
    "prepare": "husky",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:unit": "vitest --project unit",
    "test:integration": "vitest --project integration",
    "test:scripts": "vitest --project scripts",
    "test:e2e": "node scripts/test-e2e.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@google-analytics/data": "^5.2.2",
    "@next/third-parties": "16.2.4",
    "@payloadcms/admin-bar": "^3.84.1",
    "@payloadcms/db-postgres": "^3.84.1",
    "@payloadcms/live-preview-react": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/plugin-form-builder": "^3.84.1",
    "@payloadcms/plugin-nested-docs": "^3.84.1",
    "@payloadcms/plugin-redirects": "^3.84.1",
    "@payloadcms/plugin-search": "^3.84.1",
    "@payloadcms/plugin-seo": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/storage-s3": "^3.84.1",
    "@payloadcms/ui": "^3.84.1",
    "@wrksz/themes": "^0.9.2",
    "better-react-mathjax": "^3.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "embla-carousel-react": "^8.6.0",
    "feed": "^5.2.1",
    "graphql": "^16.13.2",
    "lucide-react": "^1.9.0",
    "next": "16.2.6",
    "next-sitemap": "^4.2.3",
    "payload": "^3.84.1",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.73.1",
    "sanitize-html": "^2.17.3",
    "schema-dts": "^2.0.0",
    "shadcn": "^4.4.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "16.2.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@testcontainers/postgresql": "^11.14.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/escape-html": "^1.0.4",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.1",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.0.5",
    "pg": "^8.21.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "tailwindcss": "^4.2.4",
    "testcontainers": "^11.14.0",
    "tsx": "^4.22.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.6"
  },
  "optionalDependencies": {
    "@digitalgroundgame/fonts": "1.2.0",
    "@rolldown/binding-win32-x64-msvc": "^1.0.1"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": "^10"
  }
}
