# Docker Compose Environment Variables
# Copy this file to .env and fill in your values
# For use with Coolify, set these environment variables in the Coolify UI
#
# ==============================================================
# COOLIFY BUILD SECRETS (IMPORTANT)
# ==============================================================
# These variables MUST have "Use Docker Build Secrets" ENABLED in Coolify
# so they're injected via BuildKit --mount=type=secret, never baked into layers:
#
#   - DATABASE_URI          (Build + Runtime + Build Secrets)
#   - PAYLOAD_SECRET        (Build + Runtime + Build Secrets)
#   - S3_ACCESS_KEY_ID      (Build + Runtime + Build Secrets)
#   - S3_SECRET_ACCESS_KEY  (Build + Runtime + Build Secrets)
#   - SOURCE_DATABASE_URI   (Build + Runtime + Build Secrets)
#   - GH_FONT_READ          (Build + Build Secrets)
#
# All other variables below are non-sensitive — use standard toggles.
# ==============================================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=main_db
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_MAX_CONNECTIONS=200

# preview: appends COOLIFY_FQDN prefix to database names (e.g. pragmatic_papers_pr_330)
# staging/production: uses DATABASE_URI as-is
BUILD_ENV=staging

# Automatically set by Coolify for preview deployments (e.g. "pr-330.pragmaticpapers.com")
# Leave empty for staging/production
COOLIFY_FQDN=

# GitHub Packages PAT with read:packages scope (for @digitalgroundgame fonts)
# COOLIFY: Build + Build Secrets
GH_FONT_READ=YOUR_GITHUB_TOKEN_HERE

# COOLIFY: Build + Runtime + Build Secrets
# Preview renames DB: "pragmatic_papers" -> "pragmatic_papers_pr_330" when COOLIFY_FQDN is set
DATABASE_URI=postgresql://postgres:your_secure_password_here@postgres:5432/pragmatic_papers

# Creates isolated DB copy for preview deployments to prevent schema mismatches
COPY_SOURCE_DATABASE=false

# COOLIFY: Build + Runtime + Build Secrets
SOURCE_DATABASE_URI=

# WARNING: drops existing target database before copy. Only for rebuild scenarios.
FORCE_DATABASE_COPY=false

# COOLIFY: Build + Runtime + Build Secrets
PAYLOAD_SECRET=your_secret_key_here

USE_LOCAL_STORAGE=true

S3_REGION=us-east-1
S3_BUCKET=pragmatic-papers-staging
# COOLIFY: Build + Runtime + Build Secrets
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_ENDPOINT=https://s3.amazonaws.com